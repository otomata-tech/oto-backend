# oto-mcp environment

# Public base URL (used by the OAuth provider to construct absolute URLs)
OTO_MCP_PUBLIC_URL=https://mcp.oto.ninja

# Shared password gating the OAuth login form (single-user MVP)
OTO_MCP_OAUTH_PASSWORD=change-me

# Optional overrides:
# MCP_TRANSPORT=streamable_http   # or `stdio` for local
# HOST=127.0.0.1
# PORT=9103
# LOG_LEVEL=INFO
