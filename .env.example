# oto-mcp environment

# Public base URL (used by the OAuth provider to construct absolute URLs)
OTO_MCP_PUBLIC_URL=https://mcp.oto.ninja

# Shared password gating the OAuth login form (single-user MVP)
OTO_MCP_OAUTH_PASSWORD=change-me

# Optional overrides:
# MCP_TRANSPORT=streamable_http   # or `stdio` for local
# HOST=127.0.0.1
# PORT=9103
# LOG_LEVEL=INFO

# Error tracking Sentry (SaaS). Absent → Sentry désactivé (no-op).
# OTO_SENTRY_DSN=https://<key>@<org>.ingest.de.sentry.io/<project>
# OTO_SENTRY_ENV=production
# OTO_SENTRY_RELEASE=                       # ex. SHA git du deploy (optionnel)
# OTO_SENTRY_TRACES_SAMPLE_RATE=0           # tracing de perf (0 = off)
